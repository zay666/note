<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.StackPane?>

<StackPane fx:id="widgetRoot"
           prefHeight="48.0"
           prefWidth="48.0"
           styleClass="widget-root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.notewidget.controller.WidgetController">
    <children>
        <Button fx:id="openButton"
                mnemonicParsing="false"
                onAction="#handleWidgetClick"
                styleClass="widget-button"
                text="笔记"/>
    </children>
</StackPane>
